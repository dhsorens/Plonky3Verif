-  let ⟨tmp0, tmp1, out⟩ ← (p3_util.gcd_inner ((63 : usize)) a b);
-  let a : u64 := tmp0;
-  let b : u64 := tmp1;
-  let ⟨f00, _, f10, _⟩ := out;
-  let ⟨tmp0, tmp1, out⟩ ← (p3_util.gcd_inner ((63 : usize)) a b);
-  let a : u64 := tmp0;
-  let b : u64 := tmp1;
-  let ⟨_, _, f11, g11⟩ := out;
-  let u : Goldilocks ← (from_unusual_int f00);
-  let v : Goldilocks ← (from_unusual_int f10);
-  let u_fac11 : Goldilocks ← (from_unusual_int f11);
-  let v_fac11 : Goldilocks ← (from_unusual_int g11);
-  (p3_field.field.PrimeCharacteristicRing.mul_2exp_u64
-    Goldilocks
-    (← (core_models.ops.arith.Add.add
-      Goldilocks
-      Goldilocks
-      (← (core_models.ops.arith.Mul.mul Goldilocks Goldilocks u u_fac11))
-      (← (core_models.ops.arith.Mul.mul Goldilocks Goldilocks v v_fac11))))
